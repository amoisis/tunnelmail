{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TunnelMail: Start",
      "type": "shell",
      "command": "go run ./src",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "TunnelMail: Stop",
      "type": "shell",
      "command": "pkill -f 'go run ./src' || true",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "TunnelMail: Restart",
      "dependsOn": [
        "TunnelMail: Stop",
        "TunnelMail: Start"
      ],
      "runOptions": {
        "runOn": "default"
      }
    }
  ]
}
